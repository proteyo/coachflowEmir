{
  "expo": {
    "name": "CoachFlow",
    "slug": "coachflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "coachflow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.emirkamilov.coachflow",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow CoachFlow to access your microphone to record voice messages.",
        "NSPhotoLibraryUsageDescription": "Allow CoachFlow to access your photos to set your profile picture.",
        "NSLocationWhenInUseUsageDescription": "Allow CoachFlow to show nearby gyms, nutrition spots and sport shops."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.emirkamilov.coachflow",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2563EB",
          "sounds": []
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow CoachFlow to access your microphone to record voice messages."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CoachFlow to access your photos to set your profile picture."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow CoachFlow to show nearby gyms, nutrition spots and sport shops."
        }
      ],
      "expo-asset",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "04d29e7a-8e94-47fa-866d-3a560d5f5138"
      }
    }
  }
}
